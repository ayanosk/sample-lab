{
  "permissions": {
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(credentials/**)",
      "Read(**/credentials/**)",
      "Read(secrets/**)",
      "Read(**/secrets/**)"
    ]
  }
}
